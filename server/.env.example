# คัดลอกเป็น .env แล้วเติมค่าจริง — ห้าม commit .env
# ตอน deploy ให้ตั้งค่าพวกนี้เป็น environment variables บน host แทน

# PaaS ส่วนใหญ่ (Render/Railway) กำหนด PORT ให้เอง — ปล่อยว่างได้
PORT=3001
NODE_ENV=development

# origin ของ client ที่อนุญาตให้เรียก API (CORS)
# same-origin deploy (server เสิร์ฟ client/dist เอง) ไม่ได้ใช้ค่านี้ แต่ตั้งไว้ก็ไม่เสียหาย
# ใส่หลาย origin ได้ คั่นด้วย comma
CLIENT_URL=http://localhost:5173

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=were_not_wolf

# ต้องเปลี่ยนเป็นค่าสุ่มยาว ๆ ตอน production — session ทั้งระบบขึ้นกับค่านี้
SESSION_SECRET=change-this-to-a-long-random-string

# Google OAuth (Google Cloud Console > Credentials)
# GOOGLE_CALLBACK_URL ต้องตรงเป๊ะกับที่ลงทะเบียนใน Authorized redirect URIs
# dev  : http://localhost:3001/api/auth/google/callback
# prod : https://<your-domain>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback
