# คัดลอกเป็น .env แล้วเติมค่าจริง — ห้าม commit .env
# ตอน deploy ให้ตั้งค่าพวกนี้เป็น environment variables บน host แทน

# PaaS ส่วนใหญ่ (Render/Railway) กำหนด PORT ให้เอง — ปล่อยว่างได้
PORT=3001
NODE_ENV=development

# origin ของ client ที่อนุญาตให้เรียก API (CORS)
# same-origin deploy (server เสิร์ฟ client/dist เอง) ไม่ได้ใช้ค่านี้ แต่ตั้งไว้ก็ไม่เสียหาย
# ใส่หลาย origin ได้ คั่นด้วย comma
CLIENT_URL=http://localhost:5173

# ── Database ────────────────────────────────────────────────────────────────
# local (XAMPP/MySQL ในเครื่อง): ใช้ค่าตามด้านล่างนี้ได้เลย DB_SSL=false
#
# Aiven: เอา Service URI จาก Aiven Console > Service > Overview หน้าตาแบบนี้
#   mysql://avnadmin:AVNS_xxxxxxxx@wnw-db-myproject.a.aivencloud.com:24619/defaultdb?ssl-mode=REQUIRED
#          └ DB_USER ┘└ DB_PASSWORD ┘└──────────── DB_HOST ────────────┘└DB_PORT┘└DB_NAME┘
# แล้วตั้ง DB_SSL=true + DB_CA_CERT (ดู MIGRATION.md ที่ root)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=were_not_wolf

# Aiven บังคับ TLS (ssl-mode=REQUIRED) → ตั้ง true; MySQL/MariaDB ในเครื่องไม่ได้เปิด TLS → ตั้ง false
DB_SSL=false

# ใช้เฉพาะตอน DB_SSL=true — Aiven เซ็น certificate ด้วย CA ของ project เอง (ไม่ใช่ CA สาธารณะ)
# ถ้าไม่ตั้งค่านี้จะ connect ไม่ผ่าน ("self-signed certificate in certificate chain")
# โหลด ca.pem จาก Aiven Console > Overview > "CA Certificate" แล้วชี้ path มาที่ไฟล์ (relative กับ server/)
#   DB_CA_CERT=db/ca.pem
# หรือ paste เนื้อ PEM ทั้งก้อนลงมาตรง ๆ ถ้า host ตั้ง env เป็นข้อความหลายบรรทัดได้
DB_CA_CERT=

# ต้องเปลี่ยนเป็นค่าสุ่มยาว ๆ ตอน production — session ทั้งระบบขึ้นกับค่านี้
SESSION_SECRET=change-this-to-a-long-random-string

# Google OAuth (Google Cloud Console > Credentials)
# GOOGLE_CALLBACK_URL ต้องตรงเป๊ะกับที่ลงทะเบียนใน Authorized redirect URIs
# dev  : http://localhost:3001/api/auth/google/callback
# prod : https://<your-domain>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback
